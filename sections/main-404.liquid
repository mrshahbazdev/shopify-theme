{%- comment -%}
  Bano Theme - 404 Page Section
  Custom 404 error page
{%- endcomment -%}

<section 
  id="NotFound-{{ section.id }}"
  class="section not-found min-h-[60vh] flex items-center"
  data-section-id="{{ section.id }}"
  data-section-type="404"
>
  <div class="container-custom py-16 text-center">
    
    <!-- Error Code -->
    <div class="mb-6">
      <span class="text-8xl md:text-9xl font-bold text-primary-100 select-none">
        404
      </span>
    </div>
    
    <!-- Heading -->
    <h1 class="text-3xl md:text-4xl font-bold text-text-primary mb-4">
      {{ 'general.404.title' | t }}
    </h1>
    
    <!-- Description -->
    <p class="text-lg text-text-secondary mb-8 max-w-lg mx-auto">
      {{ 'general.404.subtitle' | t }}
    </p>
    
    <!-- Search Box -->
    <div class="max-w-md mx-auto mb-10">
      <form action="{{ routes.search_url }}" method="get" class="flex gap-2">
        <input 
          type="search"
          name="q"
          class="input flex-1"
          placeholder="{{ 'general.404.search_placeholder' | t }}"
          aria-label="{{ 'general.404.search_label' | t }}"
        >
        <button type="submit" class="btn-primary px-6">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </button>
      </form>
    </div>
    
    <!-- Popular Collections -->
    {%- if section.settings.show_collections and linklists['main-menu'].links.size > 0 -%}
      <div class="mb-10">
        <h2 class="text-sm font-semibold text-text-muted uppercase tracking-wider mb-4">
          Popular Categories
        </h2>
        <div class="flex flex-wrap justify-center gap-3">
          {%- for link in linklists['main-menu'].links limit: 6 -%}
            <a 
              href="{{ link.url }}"
              class="px-4 py-2 bg-background-secondary rounded-full text-sm text-text-secondary hover:bg-primary-50 hover:text-primary-600 transition-colors"
            >
              {{ link.title }}
            </a>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
    
    <!-- Back to Home Button -->
    <a href="{{ routes.root_url }}" class="btn-primary px-8 py-4 inline-flex items-center gap-2">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      {{ 'general.404.button' | t }}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "404 Page",
  "tag": "section",
  "class": "section-404",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_collections",
      "default": true,
      "label": "Show Popular Categories"
    }
  ]
}
{% endschema %}