{%- comment -%}
  Bano Theme - Image Gallery Section
  Grid gallery with lightbox, hotspots, before/after slider
{%- endcomment -%}

<section 
  id="ImageGallery-{{ section.id }}"
  class="section image-gallery"
  data-section-id="{{ section.id }}"
  data-section-type="image-gallery"
>
  <div class="container-custom">
    
    <!-- Section Header -->
    <div class="text-center mb-10">
      {%- if section.settings.subheading != blank -%}
        <p class="text-sm font-medium text-primary-600 uppercase tracking-wider mb-2">
          {{ section.settings.subheading }}
        </p>
      {%- endif -%}
      
      {%- if section.settings.heading != blank -%}
        <h2 class="text-3xl md:text-4xl font-bold text-text-primary">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}
    </div>
    
    <!-- Gallery Grid -->
    {%- case section.settings.layout -%}
      {%- when 'grid' -%}
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          {%- for block in section.blocks -%}
            {%- when 'image' -%}
              <div 
                class="gallery-item relative overflow-hidden rounded-lg {% if block.settings.wide %}col-span-2{% endif %} {% if block.settings.tall %}row-span-2{% endif %}"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.image != blank -%}
                  <img 
                    src="{{ block.settings.image | image_url: width: 800 }}"
                    alt="{{ block.settings.alt | default: 'Gallery image' }}"
                    class="w-full h-full object-cover transition-transform duration-500 hover:scale-105 cursor-pointer"
                    loading="lazy"
                    data-gallery-lightbox
                    data-index="{{ forloop.index0 }}"
                  >
                {%- else -%}
                  <div class="aspect-square bg-background-secondary flex items-center justify-center">
                    <svg class="w-12 h-12 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                  </div>
                {%- endif -%}
                
                <!-- Optional Hotspot -->
                {%- if block.settings.hotspot_x != blank and block.settings.hotspot_y != blank -%}
                  <button 
                    type="button"
                    class="absolute w-8 h-8 bg-white rounded-full shadow-lg flex items-center justify-center hover:scale-110 transition-transform"
                    style="left: {{ block.settings.hotspot_x }}%; top: {{ block.settings.hotspot_y }}%;"
                    data-hotspot
                    data-product="{{ block.settings.hotspot_product }}"
                    aria-label="View product"
                  >
                    <span class="w-3 h-3 bg-primary-600 rounded-full animate-pulse"></span>
                  </button>
                {%- endif -%}
              </div>
            {%- endunless -%}
          {%- endfor -%}
        </div>
        
      {%- when 'slider' -%}
        <div 
          class="gallery-swiper swiper-container"
          data-gallery-swiper
        >
          <div class="swiper-wrapper">
            {%- for block in section.blocks -%}
              {%- when 'image' -%}
                <div class="swiper-slide">
                  <div class="aspect-square md:aspect-video rounded-lg overflow-hidden">
                    {%- if block.settings.image != blank -%}
                      <img 
                        src="{{ block.settings.image | image_url: width: 1200 }}"
                        alt="{{ block.settings.alt | default: 'Gallery image' }}"
                        class="w-full h-full object-cover cursor-pointer"
                        loading="lazy"
                        data-gallery-lightbox
                        data-index="{{ forloop.index0 }}"
                      >
                    {%- else -%}
                      <div class="w-full h-full bg-background-secondary flex items-center justify-center">
                        <svg class="w-12 h-12 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              {%- endunless -%}
            {%- endfor -%}
          </div>
          <div class="swiper-pagination"></div>
          <div class="swiper-button-prev"></div>
          <div class="swiper-button-next"></div>
        </div>
    {%- endcase -%}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Lightbox functionality
    const lightboxImages = document.querySelectorAll('[data-gallery-lightbox]');
    // Lightbox implementation would go here
    
    // Gallery Swiper
    const gallerySwiper = document.querySelector('[data-gallery-swiper]');
    if (gallerySwiper && typeof Swiper !== 'undefined') {
      new Swiper(gallerySwiper, {
        loop: true,
        slidesPerView: 1,
        spaceBetween: 16,
        pagination: {
          el: '.swiper-pagination',
          clickable: true,
        },
        navigation: {
          nextEl: '.swiper-button-next',
          prevEl: '.swiper-button-prev',
        },
        breakpoints: {
          768: {
            slidesPerView: 2,
          },
          1024: {
            slidesPerView: 3,
          }
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Image Gallery",
  "tag": "section",
  "class": "section-image-gallery",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "layout",
      "default": "grid",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "slider", "label": "Slider" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt Text"
        },
        {
          "type": "checkbox",
          "id": "wide",
          "default": false,
          "label": "Wide (span 2 columns)"
        },
        {
          "type": "checkbox",
          "id": "tall",
          "default": false,
          "label": "Tall (span 2 rows)"
        },
        {
          "type": "paragraph",
          "content": "Hotspot Settings"
        },
        {
          "type": "range",
          "id": "hotspot_x",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50,
          "unit": "%",
          "label": "Hotspot X Position"
        },
        {
          "type": "range",
          "id": "hotspot_y",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50,
          "unit": "%",
          "label": "Hotspot Y Position"
        },
        {
          "type": "product",
          "id": "hotspot_product",
          "label": "Hotspot Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Gallery"
    }
  ]
}
{% endschema %}