{%- comment -%}
  Bano Theme - Main Product Section
  Complete product page with gallery, variants, add to cart
{%- endcomment -%}

<section 
  id="MainProduct-{{ section.id }}"
  class="section main-product py-10 md:py-16"
  data-section-id="{{ section.id }}"
  data-section-type="product"
  data-product-id="{{ product.id }}"
>
  <div class="container-custom">
    <div class="lg:grid lg:grid-cols-2 lg:gap-12 xl:gap-16">
      
      <!-- Product Gallery -->
      <div class="product-gallery" data-product-gallery>
        <!-- Main Image -->
        <div class="relative aspect-{{ section.settings.gallery_aspect_ratio | default: 'square' }} bg-background-secondary rounded-xl overflow-hidden mb-4" data-gallery-main>
          {%- if product.featured_image != blank -%}
            <img 
              id="ProductMainImage"
              src="{{ product.featured_image | image_url: width: 1200 }}"
              alt="{{ product.featured_image.alt | escape }}"
              class="w-full h-full object-cover"
              data-image-id="{{ product.featured_image.id }}"
            >
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'w-full h-full' }}
          {%- endif -%}
          
          <!-- Sale Badge -->
          {%- if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price -%}
            <div class="absolute top-4 left-4">
              <span class="badge-sale px-3 py-1.5 text-sm font-semibold">
                {{ 'product.sale' | t }}
              </span>
            </div>
          {%- endif -%}
          
          <!-- Zoom Button -->
          {%- if section.settings.enable_zoom -%}
            <button 
              type="button"
              class="absolute bottom-4 right-4 w-10 h-10 bg-background/90 rounded-full flex items-center justify-center text-text-secondary hover:text-primary-600 transition-colors"
              data-gallery-zoom
              aria-label="Zoom image"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"></path>
              </svg>
            </button>
          {%- endif -%}
        </div>
        
        <!-- Thumbnails -->
        {%- if product.images.size > 1 -%}
          <div class="product-gallery__thumbnails grid grid-cols-4 gap-3" data-gallery-thumbnails>
            {%- for image in product.images -%}
              <button 
                type="button"
                class="aspect-square rounded-lg overflow-hidden bg-background-secondary {% if image == product.featured_image %}ring-2 ring-primary-600{% endif %}"
                data-thumbnail
                data-image-id="{{ image.id }}"
                data-image-url="{{ image | image_url: width: 1200 }}"
              >
                <img 
                  src="{{ image | image_url: width: 200 }}"
                  alt="{{ image.alt | escape }}"
                  class="w-full h-full object-cover"
                  loading="lazy"
                >
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
      
      <!-- Product Info -->
      <div class="product-info mt-8 lg:mt-0" data-product-info>
        
        <!-- Breadcrumbs -->
        <nav class="text-sm text-text-muted mb-4" aria-label="Breadcrumb">
          <ol class="flex items-center gap-2">
            <li><a href="{{ routes.root_url }}" class="hover:text-primary-600">Home</a></li>
            <li>/</li>
            <li><a href="{{ routes.collections_url }}" class="hover:text-primary-600">Collections</a></li>
            <li>/</li>
            <li class="text-text-primary">{{ product.title }}</li>
          </ol>
        </nav>
        
        <!-- Title & Vendor -->
        <div class="mb-4">
          {%- if section.settings.show_vendor and product.vendor != blank -%}
            <p class="text-sm text-text-muted uppercase tracking-wider mb-1">
              <a href="{{ product.vendor | url_for_vendor }}" class="hover:text-primary-600">
                {{ product.vendor }}
              </a>
            </p>
          {%- endif -%}
          
          <h1 class="text-2xl md:text-3xl font-bold text-text-primary">
            {{ product.title }}
          </h1>
        </div>
        
        <!-- Rating -->
        {%- if section.settings.show_rating and product.metafields.reviews.rating.value != blank -%}
          <div class="flex items-center gap-2 mb-6">
            <div class="flex items-center">
              {%- assign rating = product.metafields.reviews.rating.value -%}
              {%- for i in (1..5) -%}
                <svg class="w-4 h-4 {% if forloop.index <= rating %}text-yellow-400{% else %}text-gray-300{% endif %} fill-current" viewBox="0 0 20 20">
                  <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                </svg>
              {%- endfor -%}
            </div>
            <span class="text-sm text-text-muted">
              {{ product.metafields.reviews.rating.value | round: 1 }} ({{ product.metafields.reviews.rating_count }} {{ 'product.reviews' | t }})
            </span>
          </div>
        {%- endif -%}
        
        <!-- Price -->
        <div class="mb-6" data-price-wrapper>
          <div class="flex items-center gap-3">
            <span 
              class="text-2xl font-bold {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}text-sale{% else %}text-text-primary{% endif %}"
              data-product-price
            >
              {{ product.selected_or_first_available_variant.price | money }}
            </span>
            
            {%- if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price -%}
              <span class="text-lg text-text-muted line-through" data-compare-price>
                {{ product.selected_or_first_available_variant.compare_at_price | money }}
              </span>
              
              <span class="text-sm text-sale font-medium">
                {{ 'product.save_percent' | t: percent: product.selected_or_first_available_variant.price | times: 100.0 | divided_by: product.selected_or_first_available_variant.compare_at_price | round | append: '%' }}
              </span>
            {%- endif -%}
          </div>
          
          {%- if product.selected_or_first_available_variant.unit_price_measurement -%}
            <p class="text-sm text-text-muted mt-1">
              {{ product.selected_or_first_available_variant.unit_price | money }}/{{ product.selected_or_first_available_variant.unit_price_measurement.reference_unit }}
            </p>
          {%- endif -%}
        </div>
        
        <!-- Short Description -->
        {%- if section.settings.show_description and product.description != blank -%}
          <div class="prose prose-sm text-text-secondary mb-6">
            {{ product.description | strip_html | truncatewords: 50 }}
          </div>
        {%- endif -%}
        
        <!-- Variant Selectors -->
        <form 
          action="{{ routes.cart_add_url }}" 
          method="post" 
          enctype="multipart/form-data" 
          class="product-form"
          data-product-form="{{ product.id }}"
          data-product-handle="{{ product.handle }}"
        >
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          
          {%- for option in product.options_with_values -%}
            <div class="mb-6">
              <label class="block text-sm font-medium text-text-primary mb-3">
                {{ option.name }}: <span class="font-normal text-text-secondary">{{ option.selected_value }}</span>
              </label>
              
              {%- case option.name -%}
                {%- when 'Color' or 'Colour' -%}
                  <div class="flex flex-wrap gap-2" data-option-buttons>
                    {%- for value in option.values -%}
                      <button 
                        type="button"
                        class="color-swatch w-10 h-10 rounded-full border-2 transition-all {% if value == option.selected_value %}border-primary-600 ring-2 ring-primary-600 ring-offset-2{% else %}border-border hover:border-primary-300{% endif %}"
                        data-option-value="{{ value }}"
                        data-option-name="{{ option.name }}"
                        style="background-color: {{ value | downcase }};"
                        title="{{ value }}"
                      ></button>
                    {%- endfor -%}
                  </div>
                  
                {%- when 'Size' -%}
                  <div class="flex flex-wrap gap-2" data-option-buttons>
                    {%- for value in option.values -%}
                      <button 
                        type="button"
                        class="size-btn px-4 py-2 border-2 rounded-md text-sm font-medium transition-all {% if value == option.selected_value %}border-primary-600 bg-primary-50 text-primary-600{% else %}border-border text-text-secondary hover:border-primary-300{% endif %}"
                        data-option-value="{{ value }}"
                        data-option-name="{{ option.name }}"
                      >
                        {{ value }}
                      </button>
                    {%- endfor -%}
                  </div>
                  
                {%- else -%}
                  <div class="flex flex-wrap gap-2" data-option-buttons>
                    {%- for value in option.values -%}
                      <button 
                        type="button"
                        class="px-4 py-2 border-2 rounded-md text-sm font-medium transition-all {% if value == option.selected_value %}border-primary-600 bg-primary-50 text-primary-600{% else %}border-border text-text-secondary hover:border-primary-300{% endif %}"
                        data-option-value="{{ value }}"
                        data-option-name="{{ option.name }}"
                      >
                        {{ value }}
                      </button>
                    {%- endfor -%}
                  </div>
              {%- endcase -%}
            </div>
          {%- endfor -%}
          
          <!-- Quantity -->
          {%- if section.settings.show_quantity -%}
            <div class="mb-6">
              <label class="block text-sm font-medium text-text-primary mb-3">
                {{ 'product.quantity' | t }}
              </label>
              <div class="flex items-center gap-3">
                <div class="quantity-selector flex items-center border border-border rounded-md">
                  <button type="button" class="qty-btn px-3 py-2 hover:bg-background-secondary transition-colors" data-action="decrease">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"></path>
                    </svg>
                  </button>
                  <input 
                    type="number" 
                    name="quantity" 
                    value="1" 
                    min="1" 
                    max="{{ product.selected_or_first_available_variant.inventory_quantity | default: 99 }}"
                    class="w-16 text-center border-0 bg-transparent py-2"
                    data-quantity-input
                  >
                  <button type="button" class="qty-btn px-3 py-2 hover:bg-background-secondary transition-colors" data-action="increase">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          {%- endif -%}
          
          <!-- Stock Indicator -->
          {%- if section.settings.show_stock -%}
            {%- assign inventory = product.selected_or_first_available_variant.inventory_quantity -%}
            {%- if inventory > 0 and inventory <= 10 -%}
              <div class="mb-6 flex items-center gap-2 text-sm text-warning">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                </svg>
                {{ 'product.only_left' | t: count: inventory }}
              </div>
            {%- endif -%}
          {%- endif -%}
          
          <!-- Add to Cart & Buy Now -->
          <div class="flex flex-col sm:flex-row gap-4 mb-6">
            <button 
              type="submit"
              class="btn-primary flex-1 py-4 px-8 text-base font-semibold flex items-center justify-center gap-2"
              data-add-to-cart
              {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
            >
              {%- if product.selected_or_first_available_variant.available -%}
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
                </svg>
                {{ 'product.add_to_cart' | t }}
              {%- else -%}
                {{ 'product.sold_out' | t }}
              {%- endif -%}
            </button>
            
            {%- if section.settings.show_buy_now -%}
              <button 
                type="button"
                class="btn-secondary flex-1 py-4 px-8 text-base font-semibold"
                data-buy-now
              >
                {{ 'product.buy_now' | t }}
              </button>
            {%- endif -%}
          </div>
          
          <!-- Wishlist & Compare -->
          <div class="flex items-center gap-4 mb-8">
            <button 
              type="button"
              class="flex items-center gap-2 text-sm text-text-secondary hover:text-primary-600 transition-colors"
              data-wishlist-btn
              data-product-id="{{ product.selected_or_first_available_variant.id }}"
              data-product-url="{{ product.url }}"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
              </svg>
              {{ 'product.wishlist' | t }}
            </button>
            
            <button 
              type="button"
              class="flex items-center gap-2 text-sm text-text-secondary hover:text-primary-600 transition-colors"
              data-compare-btn
              data-product-id="{{ product.selected_or_first_available_variant.id }}"
              data-product-url="{{ product.url }}"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
              </svg>
              {{ 'product.compare' | t }}
            </button>
            
            <!-- Share -->
            <button 
              type="button"
              class="flex items-center gap-2 text-sm text-text-secondary hover:text-primary-600 transition-colors"
              data-share-btn
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path>
              </svg>
              {{ 'product.share' | t }}
            </button>
          </div>
          
          <!-- Product Details Accordion -->
          <div class="border-t border-border pt-6 space-y-4">
            {%- if section.settings.show_shipping -%}
              <details class="group">
                <summary class="flex items-center justify-between py-3 cursor-pointer">
                  <span class="font-medium text-text-primary">{{ 'product.shipping' | t }}</span>
                  <svg class="w-5 h-5 text-text-muted transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </summary>
                <div class="pb-4 text-sm text-text-secondary">
                  <p>{{ 'product.shipping_info' | t }}</p>
                  <p class="mt-2">{{ 'product.free_shipping' | t: amount: '$100' }}</p>
                </div>
              </details>
            {%- endif -%}
            
            {%- if section.settings.show_returns -%}
              <details class="group">
                <summary class="flex items-center justify-between py-3 cursor-pointer">
                  <span class="font-medium text-text-primary">{{ 'product.returns' | t }}</span>
                  <svg class="w-5 h-5 text-text-muted transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </summary>
                <div class="pb-4 text-sm text-text-secondary">
                  <p>{{ 'product.returns_info' | t }}</p>
                </div>
              </details>
            {%- endif -%}
            
            {%- if section.settings.show_product_meta -%}
              <details class="group">
                <summary class="flex items-center justify-between py-3 cursor-pointer">
                  <span class="font-medium text-text-primary">Product Details</span>
                  <svg class="w-5 h-5 text-text-muted transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </summary>
                <div class="pb-4 text-sm text-text-secondary space-y-2">
                  {%- if product.vendor != blank -%}
                    <p><span class="font-medium">{{ 'product.vendor' | t }}:</span> {{ product.vendor }}</p>
                  {%- endif -%}
                  {%- if product.type != blank -%}
                    <p><span class="font-medium">{{ 'product.type' | t }}:</span> {{ product.type }}</p>
                  {%- endif -%}
                  {%- if product.selected_or_first_available_variant.sku != blank -%}
                    <p><span class="font-medium">{{ 'product.sku' | t }}:</span> {{ product.selected_or_first_available_variant.sku }}</p>
                  {%- endif -%}
                </div>
              </details>
            {%- endif -%}
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  // Product Page JavaScript
  document.addEventListener('DOMContentLoaded', function() {
    const productForm = document.querySelector('[data-product-form="{{ product.id }}"]');
    if (!productForm) return;

    // Gallery thumbnails
    document.querySelectorAll('[data-thumbnail]').forEach(thumb => {
      thumb.addEventListener('click', () => {
        const mainImg = document.getElementById('ProductMainImage');
        mainImg.src = thumb.dataset.imageUrl;
        
        document.querySelectorAll('[data-thumbnail]').forEach(t => {
          t.classList.remove('ring-2', 'ring-primary-600');
        });
        thumb.classList.add('ring-2', 'ring-primary-600');
      });
    });

    // Option buttons
    document.querySelectorAll('[data-option-buttons] button').forEach(btn => {
      btn.addEventListener('click', () => {
        const container = btn.closest('[data-option-buttons]');
        const optionName = btn.dataset.optionName;
        
        // Update selection
        container.querySelectorAll('button').forEach(b => {
          b.classList.remove('border-primary-600', 'bg-primary-50', 'text-primary-600', 'ring-2', 'ring-primary-600', 'ring-offset-2');
          b.classList.add('border-border', 'text-text-secondary');
        });
        btn.classList.remove('border-border', 'text-text-secondary');
        btn.classList.add('border-primary-600', 'bg-primary-50', 'text-primary-600');
        
        // Update variant
        const selectedValue = btn.dataset.optionValue;
        updateVariant(optionName, selectedValue);
      });
    });

    // Update variant based on selection
    function updateVariant(optionName, value) {
      const formData = new FormData(productForm);
      const selectedOptions = {};
      
      formData.forEach((val, key) => {
        if (key.startsWith('option_')) {
          selectedOptions[key] = val;
        }
      });
      
      // This would need to query the product variants
      // For now, just update the form
    }

    // Quantity buttons
    const qtyInput = productForm.querySelector('[data-quantity-input]');
    productForm.querySelectorAll('.qty-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const action = btn.dataset.action;
        let value = parseInt(qtyInput.value);
        
        if (action === 'decrease' && value > 1) {
          qtyInput.value = value - 1;
        } else if (action === 'increase') {
          qtyInput.value = value + 1;
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Product",
  "tag": "section",
  "class": "section-product",
  "settings": [
    {
      "type": "select",
      "id": "gallery_layout",
      "default": "thumbnails",
      "label": "Gallery Layout",
      "options": [
        { "value": "thumbnails", "label": "Thumbnails" },
        { "value": "carousel", "label": "Carousel" },
        { "value": "grid", "label": "Grid" }
      ]
    },
    {
      "type": "select",
      "id": "gallery_aspect_ratio",
      "default": "square",
      "label": "Image Aspect Ratio",
      "options": [
        { "value": "square", "label": "Square (1:1)" },
        { "value": "portrait", "label": "Portrait (3:4)" },
        { "value": "landscape", "label": "Landscape (4:3)" }
      ]
    },
    {
      "type": "checkbox",
      "id": "enable_zoom",
      "default": true,
      "label": "Enable Image Zoom"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Show Vendor"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": true,
      "label": "Show Rating"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "default": true,
      "label": "Show Short Description"
    },
    {
      "type": "checkbox",
      "id": "show_quantity",
      "default": true,
      "label": "Show Quantity Selector"
    },
    {
      "type": "checkbox",
      "id": "show_stock",
      "default": true,
      "label": "Show Stock Indicator"
    },
    {
      "type": "checkbox",
      "id": "show_buy_now",
      "default": true,
      "label": "Show Buy Now Button"
    },
    {
      "type": "checkbox",
      "id": "show_shipping",
      "default": true,
      "label": "Show Shipping Info"
    },
    {
      "type": "checkbox",
      "id": "show_returns",
      "default": true,
      "label": "Show Returns Info"
    },
    {
      "type": "checkbox",
      "id": "show_product_meta",
      "default": true,
      "label": "Show Product Details"
    }
  ]
}
{% endschema %}