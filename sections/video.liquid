{%- comment -%}
  Bano Theme - Video Section
  YouTube/Vimeo embed with poster image
{%- endcomment -%}

<section 
  id="Video-{{ section.id }}"
  class="section video"
  data-section-id="{{ section.id }}"
  data-section-type="video"
>
  <div class="container-custom">
    
    <!-- Section Header -->
    {%- if section.settings.heading != blank -%}
      <div class="text-center mb-10">
        {%- if section.settings.subheading != blank -%}
          <p class="text-sm font-medium text-primary-600 uppercase tracking-wider mb-2">
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}
        
        <h2 class="text-3xl md:text-4xl font-bold text-text-primary">
          {{ section.settings.heading }}
        </h2>
      </div>
    {%- endif -%}
    
    <!-- Video Container -->
    <div class="max-w-5xl mx-auto">
      <div 
        class="video-wrapper relative rounded-xl overflow-hidden {% if section.settings.full_width %}full-width{% endif %}"
        style="aspect-ratio: {{ section.settings.aspect_ratio | default: '16/9' }}"
      >
        {%- if section.settings.video_url != blank -%}
          <!-- Video Embed -->
          {%- if section.settings.video_url.type == 'youtube' -%}
            <iframe
              src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?enablejsapi=1&rel=0{% if section.settings.autoplay %}&autoplay=1{% endif %}"
              class="absolute inset-0 w-full h-full"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          {%- elsif section.settings.video_url.type == 'vimeo' -%}
            <iframe
              src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}?autoplay={{ section.settings.autoplay }}{% if section.settings.autoplay %}&muted=1{% endif %}"
              class="absolute inset-0 w-full h-full"
              frameborder="0"
              allow="autoplay; fullscreen; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          {%- else -%}
            <video
              src="{{ section.settings.video_url }}"
              class="absolute inset-0 w-full h-full object-cover"
              {% if section.settings.autoplay %}autoplay muted loop{% endif %}
              playsinline
              controls
            ></video>
          {%- endif -%}
        {%- elsif section.settings.video_id != blank -%}
          <!-- YouTube/Vimeo by ID -->
          {%- if section.settings.video_type == 'youtube' -%}
            <iframe
              src="https://www.youtube.com/embed/{{ section.settings.video_id }}?enablejsapi=1&rel=0"
              class="absolute inset-0 w-full h-full"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          {%- else -%}
            <iframe
              src="https://player.vimeo.com/video/{{ section.settings.video_id }}"
              class="absolute inset-0 w-full h-full"
              frameborder="0"
              allow="autoplay; fullscreen; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          {%- endif -%}
        {%- else -%}
          <!-- Poster Image with Play Button -->
          <div class="absolute inset-0 bg-background-secondary">
            {%- if section.settings.poster != blank -%}
              <img 
                src="{{ section.settings.poster | image_url: width: 1280 }}"
                alt="{{ section.settings.heading | default: 'Video' }}"
                class="w-full h-full object-cover"
                loading="lazy"
              >
            {%- endif -%}
            
            <button 
              type="button"
              class="video-play-btn absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-20 h-20 bg-white/90 hover:bg-white rounded-full flex items-center justify-center shadow-lg transition-all duration-300 hover:scale-110"
              data-video-play
              aria-label="Play video"
            >
              <svg class="w-8 h-8 text-text-primary ml-1" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </button>
          </div>
        {%- endif -%}
      </div>
    </div>
    
    <!-- Caption -->
    {%- if section.settings.caption != blank -%}
      <p class="text-center text-text-muted mt-4">
        {{ section.settings.caption }}
      </p>
    {%- endif -%}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const playBtns = document.querySelectorAll('[data-video-play]');
    
    playBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const wrapper = btn.closest('.video-wrapper');
        // This would typically load the video iframe dynamically
        console.log('Video play clicked');
      });
    });
  });
</script>

{% schema %}
{
  "name": "Video",
  "tag": "section",
  "class": "section-video",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "Video URL",
      "accept": ["youtube", "vimeo"],
      "info": "Enter YouTube or Vimeo URL"
    },
    {
      "type": "text",
      "id": "video_id",
      "label": "Video ID",
      "info": "YouTube or Vimeo video ID (alternative to URL)"
    },
    {
      "type": "select",
      "id": "video_type",
      "default": "youtube",
      "label": "Video Type",
      "options": [
        { "value": "youtube", "label": "YouTube" },
        { "value": "vimeo", "label": "Vimeo" }
      ]
    },
    {
      "type": "image_picker",
      "id": "poster",
      "label": "Poster Image",
      "info": "Image shown before video plays"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "default": false,
      "label": "Autoplay Video"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "default": "16/9",
      "label": "Aspect Ratio",
      "options": [
        { "value": "16/9", "label": "16:9" },
        { "value": "21/9", "label": "21:9" },
        { "value": "4/3", "label": "4:3" }
      ]
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "default": false,
      "label": "Full Width"
    }
  ],
  "presets": [
    {
      "name": "Video",
      "settings": {
        "heading": "Watch Our Story",
        "aspect_ratio": "16/9"
      }
    }
  ]
}
{% endschema %}