{%- comment -%}
  Bano Theme - Blog Posts Section
  Article cards with category filter
{%- endcomment -%}

<section 
  id="BlogPosts-{{ section.id }}"
  class="section blog-posts"
  data-section-id="{{ section.id }}"
  data-section-type="blog-posts"
>
  <div class="container-custom">
    
    <!-- Section Header -->
    <div class="text-center mb-10">
      {%- if section.settings.subheading != blank -%}
        <p class="text-sm font-medium text-primary-600 uppercase tracking-wider mb-2">
          {{ section.settings.subheading }}
        </p>
      {%- endif -%}
      
      {%- if section.settings.heading != blank -%}
        <h2 class="text-3xl md:text-4xl font-bold text-text-primary">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}
    </div>
    
    <!-- Blog Grid -->
    {%- if section.settings.blog != blank -%}
      {%- assign articles = section.settings.blog.articles -%}
    {%- else -%}
      {%- assign articles = '' -%}
    {%- endif -%}
    
    {%- if articles.size > 0 -%}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {%- for article in articles limit: section.settings.posts_to_show -%}
          <article class="blog-card group">
            <a href="{{ article.url }}" class="block">
              <!-- Image -->
              <div class="aspect-16/9 rounded-lg overflow-hidden mb-4 bg-background-secondary">
                {%- if article.image != blank -%}
                  <img 
                    src="{{ article.image | image_url: width: 600 }}"
                    alt="{{ article.image.alt | default: article.title }}"
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  >
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'w-full h-full object-cover' }}
                {%- endif -%}
              </div>
              
              <!-- Content -->
              <div>
                <!-- Meta -->
                <div class="flex items-center gap-3 text-sm text-text-muted mb-2">
                  <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                    {{ article.published_at | date: '%B %d, %Y' }}
                  </time>
                  {%- if article.comments_count > 0 -%}
                    <span class="flex items-center gap-1">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                      </svg>
                      {{ article.comments_count }}
                    </span>
                  {%- endif -%}
                </div>
                
                <!-- Title -->
                <h3 class="text-lg font-semibold text-text-primary group-hover:text-primary-600 transition-colors mb-2 line-clamp-2">
                  {{ article.title }}
                </h3>
                
                <!-- Excerpt -->
                {%- if article.excerpt != blank -%}
                  <p class="text-text-secondary text-sm line-clamp-2">
                    {{ article.excerpt }}
                  </p>
                {%- endif -%}
                
                <!-- Read More -->
                <span class="inline-flex items-center gap-1 text-sm font-medium text-primary-600 mt-3">
                  {{ 'testimonials.read_more' | t }}
                  <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                  </svg>
                </span>
              </div>
            </a>
          </article>
        {%- endfor -%}
      </div>
      
      {%- if section.settings.show_view_all -%}
        <div class="text-center mt-10">
          <a 
            href="{{ section.settings.blog.url }}"
            class="btn-outline px-8 py-3"
          >
            View All Posts
          </a>
        </div>
      {%- endif -%}
    {%- else -%}
      <!-- Empty State -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {%- for i in (1..3) -%}
          <article class="blog-card group">
            <div class="aspect-16/9 rounded-lg overflow-hidden mb-4 bg-background-secondary">
              {{ 'image' | placeholder_svg_tag: 'w-full h-full object-cover bg-gray-100' }}
            </div>
            <div class="text-sm text-text-muted mb-2">January 1, 2024</div>
            <h3 class="text-lg font-semibold text-text-primary mb-2">Sample Blog Post Title</h3>
            <p class="text-text-secondary text-sm line-clamp-2">
              This is a sample blog post excerpt. It demonstrates how blog posts will appear on your store.
            </p>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Blog Posts",
  "tag": "section",
  "class": "section-blog-posts",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "Latest News",
      "label": "Heading"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "posts_to_show",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 3,
      "label": "Posts to Show"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "Show View All Button"
    }
  ],
  "presets": [
    {
      "name": "Blog Posts",
      "settings": {
        "heading": "Latest News",
        "posts_to_show": 3
      }
    }
  ]
}
{% endschema %}