{%- comment -%}
  Bano Theme - Footer Section
  Multi-column footer with newsletter, social links, and payment icons
{%- endcomment -%}

{%- liquid
  assign footer_style = settings.footer_style
  assign show_newsletter = settings.newsletter_enabled
  assign show_social = true
  assign show_payment = settings.show_payment_icons
  assign current_year = 'now' | date: '%Y'
-%}

<footer class="footer bg-background-secondary border-t border-border">
  
  {%- if show_newsletter -%}
    <!-- Newsletter Section -->
    <div class="bg-primary-600 text-white">
      <div class="container-custom py-10 md:py-14">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6">
          <div class="text-center md:text-left">
            <h3 class="text-xl md:text-2xl font-semibold mb-2">
              {{ settings.newsletter_heading | default: 'Join Our Newsletter' }}
            </h3>
            <p class="text-white/80 text-sm md:text-base">
              {{ settings.newsletter_subheading | default: 'Subscribe to get special offers, free giveaways, and exclusive deals.' }}
            </p>
          </div>
          
          <div class="w-full md:w-auto flex-shrink-0">
            {%- form 'customer', class: 'newsletter-form flex flex-col sm:flex-row gap-3' -%}
              <input type="hidden" name="contact[tags]" value="newsletter">
              
              <div class="relative flex-1 sm:flex-initial sm:w-72">
                <input 
                  type="email"
                  name="contact[email]"
                  id="NewsletterForm-{{ section.id }}"
                  class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-md text-white placeholder-white/60 focus:outline-none focus:ring-2 focus:ring-white/50 focus:border-transparent"
                  placeholder="{{ 'footer.newsletter.placeholder' | t }}"
                  required
                >
              </div>
              
              <button 
                type="submit"
                class="px-6 py-3 bg-white text-primary-600 font-medium rounded-md hover:bg-white/90 transition-colors flex items-center justify-center gap-2"
                name="commit"
              >
                <span>{{ settings.newsletter_button_text | default: 'Subscribe' }}</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </button>
            {%- endform -%}
            
            {%- if form.posted_successfully? -%}
              <p class="mt-4 text-white text-center md:text-left">
                {{ 'footer.newsletter.success' | t }}
              </p>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}
  
  <!-- Main Footer -->
  <div class="container-custom py-12 md:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      
      <!-- Shop Column -->
      <div class="footer__column">
        <h4 class="footer__heading text-sm font-semibold text-text-primary uppercase tracking-wider mb-4">
          {{ 'general.meta.shop' | t }}
        </h4>
        <ul class="footer__links space-y-3">
          {%- for link in linklists[section.settings.shop_linklist].links -%}
            <li>
              <a 
                href="{{ link.url }}" 
                class="text-text-secondary hover:text-primary-600 transition-colors text-sm"
                {% if link.active %}aria-current="page"{% endif %}
              >
                {{ link.title }}
              </a>
            </li>
          {%- else -%}
            <li><a href="/collections/all" class="text-text-secondary hover:text-primary-600 transition-colors text-sm">All Products</a></li>
            <li><a href="/collections/new" class="text-text-secondary hover:text-primary-600 transition-colors text-sm">New Arrivals</a></li>
            <li><a href="/collections/best-sellers" class="text-text-secondary hover:text-primary-600 transition-colors text-sm">Best Sellers</a></li>
            <li><a href="/collections/sale" class="text-text-secondary hover:text-primary-600 transition-colors text-sm">Sale</a></li>
          {%- endfor -%}
        </ul>
      </div>
      
      <!-- Customer Service Column -->
      <div class="footer__column">
        <h4 class="footer__heading text-sm font-semibold text-text-primary uppercase tracking-wider mb-4">
          Customer Service
        </h4>
        <ul class="footer__links space-y-3">
          {%- for link in linklists[section.settings.customer_linklist].links -%}
            <li>
              <a 
                href="{{ link.url }}" 
                class="text-text-secondary hover:text-primary-600 transition-colors text-sm"
                {% if link.active %}aria-current="page"{% endif %}
              >
                {{ link.title }}
              </a>
            </li>
          {%- else -%}
            <li><a href="/pages/contact" class="text-text-secondary hover:text-primary-600 transition-colors text-sm">Contact Us</a></li>
            <li><a href="/pages/shipping" class="text-text-secondary hover:text-primary-600 transition-colors text-sm">Shipping Info</a></li>
            <li><a href="/pages/returns" class="text-text-secondary hover:text-primary-600 transition-colors text-sm">Returns & Exchanges</a></li>
            <li><a href="/pages/faq" class="text-text-secondary hover:text-primary-600 transition-colors text-sm">FAQ</a></li>
          {%- endfor -%}
        </ul>
      </div>
      
      <!-- About Column -->
      <div class="footer__column">
        <h4 class="footer__heading text-sm font-semibold text-text-primary uppercase tracking-wider mb-4">
          About Us
        </h4>
        <ul class="footer__links space-y-3">
          {%- for link in linklists[section.settings.about_linklist].links -%}
            <li>
              <a 
                href="{{ link.url }}" 
                class="text-text-secondary hover:text-primary-600 transition-colors text-sm"
                {% if link.active %}aria-current="page"{% endif %}
              >
                {{ link.title }}
              </a>
            </li>
          {%- else -%}
            <li><a href="/pages/about-us" class="text-text-secondary hover:text-primary-600 transition-colors text-sm">About Us</a></li>
            <li><a href="/pages/our-story" class="text-text-secondary hover:text-primary-600 transition-colors text-sm">Our Story</a></li>
            <li><a href="/pages/careers" class="text-text-secondary hover:text-primary-600 transition-colors text-sm">Careers</a></li>
            <li><a href="/pages/sustainability" class="text-text-secondary hover:text-primary-600 transition-colors text-sm">Sustainability</a></li>
          {%- endfor -%}
        </ul>
      </div>
      
      <!-- Contact & Social Column -->
      <div class="footer__column">
        <h4 class="footer__heading text-sm font-semibold text-text-primary uppercase tracking-wider mb-4">
          Get in Touch
        </h4>
        
        {%- if section.settings.footer_contact_text != blank -%}
          <p class="text-text-secondary text-sm mb-4">
            {{ section.settings.footer_contact_text }}
          </p>
        {%- endif -%}
        
        {%- if section.settings.footer_email != blank -%}
          <a 
            href="mailto:{{ section.settings.footer_email }}" 
            class="text-primary-600 hover:text-primary-700 text-sm mb-4 block"
          >
            {{ section.settings.footer_email }}
          </a>
        {%- endif -%}
        
        <!-- Social Links -->
        {%- if show_social -%}
          <div class="flex items-center gap-3 mt-6">
            {%- if settings.social_facebook != blank -%}
              <a 
                href="{{ settings.social_facebook }}" 
                target="_blank"
                rel="noopener"
                class="w-9 h-9 flex items-center justify-center bg-background-secondary rounded-full hover:bg-primary-600 hover:text-white transition-colors text-text-secondary"
                aria-label="Facebook"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </a>
            {%- endif -%}
            
            {%- if settings.social_twitter != blank -%}
              <a 
                href="{{ settings.social_twitter }}" 
                target="_blank"
                rel="noopener"
                class="w-9 h-9 flex items-center justify-center bg-background-secondary rounded-full hover:bg-primary-600 hover:text-white transition-colors text-text-secondary"
                aria-label="Twitter"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </a>
            {%- endif -%}
            
            {%- if settings.social_instagram != blank -%}
              <a 
                href="{{ settings.social_instagram }}" 
                target="_blank"
                rel="noopener"
                class="w-9 h-9 flex items-center justify-center bg-background-secondary rounded-full hover:bg-primary-600 hover:text-white transition-colors text-text-secondary"
                aria-label="Instagram"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </a>
            {%- endif -%}
            
            {%- if settings.social_pinterest != blank -%}
              <a 
                href="{{ settings.social_pinterest }}" 
                target="_blank"
                rel="noopener"
                class="w-9 h-9 flex items-center justify-center bg-background-secondary rounded-full hover:bg-primary-600 hover:text-white transition-colors text-text-secondary"
                aria-label="Pinterest"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.627 0-12 5.372-12 12 0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146 1.124.347 2.317.535 3.554.535 6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/>
                </svg>
              </a>
            {%- endif -%}
            
            {%- if settings.social_youtube != blank -%}
              <a 
                href="{{ settings.social_youtube }}" 
                target="_blank"
                rel="noopener"
                class="w-9 h-9 flex items-center justify-center bg-background-secondary rounded-full hover:bg-primary-600 hover:text-white transition-colors text-text-secondary"
                aria-label="YouTube"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              </a>
            {%- endif -%}
            
            {%- if settings.social_tiktok != blank -%}
              <a 
                href="{{ settings.social_tiktok }}" 
                target="_blank"
                rel="noopener"
                class="w-9 h-9 flex items-center justify-center bg-background-secondary rounded-full hover:bg-primary-600 hover:text-white transition-colors text-text-secondary"
                aria-label="TikTok"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
                </svg>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
  
  <!-- Bottom Bar -->
  <div class="border-t border-border">
    <div class="container-custom py-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        
        <!-- Copyright -->
        <p class="text-sm text-text-muted text-center md:text-left">
          {{ 'footer.copyright' | t: year: current_year, shop_name: shop.name }}
        </p>
        
        <!-- Payment Icons -->
        {%- if show_payment -%}
          <div class="flex items-center gap-2">
            {%- for type in shop.enabled_payment_types -%}
              <div class="w-10 h-6 bg-background-secondary rounded flex items-center justify-center">
                {{ type | payment_type_svg_tag: class: 'h-full' }}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
        
        <!-- Language/Currency -->
        <div class="flex items-center gap-4 text-sm">
          {%- if localization.available_countries.size > 1 -%}
            <div class="relative">
              {%- form 'localization', class: 'flex items-center gap-2' -%}
                <select 
                  name="country_code"
                  class="bg-transparent border border-border rounded px-2 py-1 text-text-secondary hover:border-primary-600 focus:outline-none focus:border-primary-600"
                >
                  {%- for country in localization.available_countries -%}
                    <option 
                      value="{{ country.iso_code }}" 
                      {% if country.iso_code == localization.country.iso_code %}selected{% endif %}
                    >
                      {{ country.name }} ({{ country.currency.iso_code }})
                    </option>
                  {%- endfor -%}
                </select>
                <button type="submit" class="sr-only">Update</button>
              {%- endform -%}
            </div>
          {%- endif -%}
          
          {%- if localization.available_languages.size > 1 -%}
            <div class="relative">
              {%- form 'localization', class: 'flex items-center gap-2' -%}
                <select 
                  name="locale_code"
                  class="bg-transparent border border-border rounded px-2 py-1 text-text-secondary hover:border-primary-600 focus:outline-none focus:border-primary-600"
                >
                  {%- for language in localization.available_languages -%}
                    <option 
                      value="{{ language.iso_code }}" 
                      {% if language.iso_code == localization.language.iso_code %}selected{% endif %}
                    >
                      {{ language.endonym_name | capitalize }}
                    </option>
                  {%- endfor -%}
                </select>
                <button type="submit" class="sr-only">Update</button>
              {%- endform -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "class": "section-footer",
  "settings": [
    {
      "type": "link_list",
      "id": "shop_linklist",
      "default": "footer",
      "label": "Shop Links"
    },
    {
      "type": "link_list",
      "id": "customer_linklist",
      "default": "customer-service",
      "label": "Customer Service Links"
    },
    {
      "type": "link_list",
      "id": "about_linklist",
      "default": "about-us",
      "label": "About Links"
    },
    {
      "type": "textarea",
      "id": "footer_contact_text",
      "label": "Contact Text"
    },
    {
      "type": "text",
      "id": "footer_email",
      "label": "Contact Email"
    }
  ]
}
{% endschema %}