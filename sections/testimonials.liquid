{%- comment -%}
  Bano Theme - Testimonials Section
  Customer reviews carousel with ratings
{%- endcomment -%}

<section 
  id="Testimonials-{{ section.id }}"
  class="section testimonials bg-background-secondary"
  data-section-id="{{ section.id }}"
  data-section-type="testimonials"
>
  <div class="container-custom">
    
    <!-- Section Header -->
    <div class="text-center mb-12">
      {%- if section.settings.subheading != blank -%}
        <p class="text-sm font-medium text-primary-600 uppercase tracking-wider mb-2">
          {{ section.settings.subheading }}
        </p>
      {%- endif -%}
      
      {%- if section.settings.heading != blank -%}
        <h2 class="text-3xl md:text-4xl font-bold text-text-primary">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}
    </div>
    
    <!-- Testimonials Carousel -->
    {%- if section.blocks.size > 0 -%}
      <div 
        class="testimonials-swiper swiper-container"
        data-testimonials-swiper
        data-autoplay="{{ section.settings.autoplay }}"
        data-autoplay-speed="{{ section.settings.autoplay_speed | times: 1000 }}"
      >
        <div class="swiper-wrapper pb-12">
          {%- for block in section.blocks -%}
            {%- when 'testimonial' -%}
              <div class="swiper-slide h-auto">
                <div class="bg-background rounded-xl p-8 shadow-sm border border-border h-full">
                  <!-- Rating Stars -->
                  {%- if block.settings.rating > 0 -%}
                    <div class="flex items-center gap-1 mb-4">
                      {%- for i in (1..5) -%}
                        <svg 
                          class="w-5 h-5 {% if i <= block.settings.rating %}text-yellow-400{% else %}text-gray-300{% endif %} fill-current"
                          viewBox="0 0 20 20"
                        >
                          <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                        </svg>
                      {%- endfor -%}
                    </div>
                  {%- endif -%}
                  
                  <!-- Quote -->
                  <blockquote class="text-text-primary mb-6">
                    <svg class="w-8 h-8 text-primary-200 mb-4" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
                    </svg>
                    <p class="text-lg leading-relaxed">{{ block.settings.quote }}</p>
                  </blockquote>
                  
                  <!-- Author -->
                  <div class="flex items-center gap-4">
                    {%- if block.settings.avatar != blank -%}
                      <img 
                        src="{{ block.settings.avatar | image_url: width: 64 }}"
                        alt="{{ block.settings.author }}"
                        class="w-12 h-12 rounded-full object-cover"
                      >
                    {%- else -%}
                      <div class="w-12 h-12 rounded-full bg-primary-100 flex items-center justify-center">
                        <span class="text-primary-600 font-semibold text-lg">
                          {{ block.settings.author | slice: 0, 1 | upcase }}
                        </span>
                      </div>
                    {%- endif -%}
                    
                    <div>
                      <p class="font-semibold text-text-primary">{{ block.settings.author }}</p>
                      {%- if block.settings.location != blank -%}
                        <p class="text-sm text-text-muted">{{ block.settings.location }}</p>
                      {%- endif -%}
                    </div>
                    
                    {%- if block.settings.verified -%}
                      <span class="ml-auto flex items-center gap-1 text-xs text-success font-medium">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        {{ 'testimonials.verified' | t }}
                      </span>
                    {%- endif -%}
                  </div>
                </div>
              </div>
          {%- endunless -%}
        </div>
        
        <!-- Pagination -->
        <div class="testimonials-pagination swiper-pagination"></div>
      </div>
    {%- else -%}
      <!-- Empty State -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {%- for i in (1..3) -%}
          <div class="bg-background rounded-xl p-8 shadow-sm border border-border">
            <div class="flex items-center gap-1 mb-4">
              {%- for j in (1..5) -%}
                <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20">
                  <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                </svg>
              {%- endfor -%}
            </div>
            <p class="text-lg text-text-primary mb-6">Great products and excellent customer service. Highly recommended!</p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-primary-100 flex items-center justify-center">
                <span class="text-primary-600 font-semibold">S</span>
              </div>
              <div>
                <p class="font-semibold text-text-primary">Sarah Johnson</p>
                <p class="text-sm text-text-muted">Verified Buyer</p>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const swiperEl = document.querySelector('[data-testimonials-swiper]');
    if (!swiperEl || typeof Swiper === 'undefined') return;

    const autoplay = swiperEl.dataset.autoplay === 'true';
    const autoplaySpeed = parseInt(swiperEl.dataset.autoplaySpeed) || 5000;

    new Swiper(swiperEl, {
      loop: true,
      autoplay: autoplay ? {
        delay: autoplaySpeed,
        disableOnInteraction: false,
      } : false,
      slidesPerView: 1,
      spaceBetween: 24,
      pagination: {
        el: '.testimonials-pagination',
        clickable: true,
      },
      breakpoints: {
        640: {
          slidesPerView: 2,
        },
        1024: {
          slidesPerView: 3,
        }
      }
    });
  });
</script>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section-testimonials",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "What Our Customers Say",
      "label": "Heading"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "default": true,
      "label": "Auto-play"
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 5,
      "unit": "sec",
      "label": "Autoplay Speed"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "default": "This product exceeded my expectations. The quality is outstanding and the shipping was incredibly fast. Will definitely order again!",
          "label": "Quote"
        },
        {
          "type": "text",
          "id": "author",
          "default": "Sarah Johnson",
          "label": "Author Name"
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location"
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar Image"
        },
        {
          "type": "range",
          "id": "rating",
          "min": 0,
          "max": 5,
          "step": 1,
          "default": 5,
          "label": "Rating"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "default": true,
          "label": "Show Verified Badge"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "Amazing products and excellent customer service!",
            "author": "John Smith",
            "rating": 5
          }
        }
      ]
    }
  ]
}
{% endschema %}