<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}" dir="{% if settings.rtl_enabled %}rtl{% else %}ltr{% endif %}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="{{ settings.color_primary }}">
  
  <!-- Preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  
  <!-- Title -->
  <title>{{ shop.name }} - {{ 'general.password.title' | t }}</title>
  
  <!-- Meta -->
  <meta name="description" content="{{ shop.name }} - {{ 'general.password.meta' | t }}">
  
  <!-- Favicon -->
  {%- if settings.favicon -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
  {%- endif -%}
  
  <!-- CSS -->
  {{ 'styles.css' | asset_url | stylesheet_tag }}
  
  <!-- Shopify Header -->
  {{ content_for_header }}
</head>

<body class="min-h-screen flex items-center justify-center bg-background">
  <div class="max-w-md w-full px-6 py-12 text-center">
    <!-- Logo -->
    {%- if settings.logo -%}
      <img 
        src="{{ settings.logo | image_url: width: 200 }}" 
        alt="{{ shop.name }}"
        class="mx-auto mb-8"
        style="max-width: {{ settings.logo_width }}px;"
      >
    {%- else -%}
      <h1 class="text-3xl font-bold text-text-primary mb-8">{{ shop.name }}</h1>
    {%- endif -%}
    
    <!-- Password Form -->
    <div class="card p-8">
      <h2 class="text-xl font-semibold text-text-primary mb-4">
        {{ 'general.password.enter_store' | t }}
      </h2>
      
      {%- form 'storefront_password', class: 'password-form' -%}
        {%- if form.errors -%}
          <div class="bg-error/10 text-error text-sm p-3 rounded-md mb-4">
            {{ 'general.password.wrong_password' | t }}
          </div>
        {%- endif -%}
        
        <div class="flex gap-2">
          <input 
            type="password" 
            name="password" 
            id="Password"
            class="input flex-1"
            placeholder="{{ 'general.password.password_placeholder' | t }}"
            autocomplete="off"
            required
          >
          <button type="submit" class="btn-primary px-6">
            {{ 'general.password.enter' | t }}
          </button>
        </div>
      {%- endform -%}
      
      <!-- Admin Link -->
      <div class="mt-6 pt-6 border-t border-border">
        <a href="/admin" class="text-sm text-text-muted hover:text-primary-600 transition-colors">
          {{ 'general.password.store_owner' | t }}
        </a>
      </div>
    </div>
  </div>
  
  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>